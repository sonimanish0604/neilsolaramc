# Phase 1B Integration Template
# Copy the required values into your runtime env file (for example backend/.env.local).

# Approval link and token lifecycle
APPROVAL_BASE_URL=https://app.neilsolar.com/approve
APPROVAL_TOKEN_TTL_HOURS=72

# Twilio WhatsApp Sandbox
# Keep TWILIO_ENABLED=false until credentials are ready.
TWILIO_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Twilio Sandbox sender is usually whatsapp:+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_REQUEST_TIMEOUT_SECONDS=10

# Branding for PDF layout in Phase 1B
PDF_BRAND_LABEL=NEIL Solar AMC
REPORT_STORAGE_BACKEND=AUTO
LOCAL_REPORTS_DIR=/tmp/neilsolar-reports

# Notification Engine (Phase B skeleton)
NOTIFICATION_POLL_INTERVAL_SECONDS=5
NOTIFICATION_BATCH_SIZE=20
NOTIFICATION_RETRY_MAX_ATTEMPTS=3
NOTIFICATION_RETRY_DELAY_SECONDS=60
NOTIFICATION_ARCHIVE_INTERVAL_SECONDS=3600
NOTIFICATION_PURGE_INTERVAL_SECONDS=86400
NOTIFICATION_MAINTENANCE_RUN_ONCE=false
NOTIFICATION_RETENTION_ACTIVE_DAYS_DEFAULT=7
NOTIFICATION_RETENTION_HISTORY_DAYS_DEFAULT=365
NOTIFICATION_RETENTION_DEAD_LETTER_DAYS_DEFAULT=365
NOTIFICATION_PURGE_AFTER_DEACTIVATION_DAYS_DEFAULT=90

# Secret manager strategy:
# - ENV: read inline env values (default)
# - VAULT: read secret refs from HashiCorp Vault
# - GCP: read secret refs from Google Secret Manager
SECRET_PROVIDER=ENV
SECRET_FAIL_OPEN=true
SECRET_CACHE_TTL_SECONDS=300
SECRET_FETCH_TIMEOUT_SECONDS=10

# Vault config (used when SECRET_PROVIDER=VAULT)
# For docker compose on host, use host.docker.internal to reach local Vault.
VAULT_ADDR=http://host.docker.internal:8200
VAULT_TOKEN=
VAULT_MOUNT=secret
VAULT_KV_VERSION=2

# GCP config (used when SECRET_PROVIDER=GCP)
GCP_PROJECT_ID=

# Email channel (enable first)
NOTIFICATION_EMAIL_ENABLED=true
NOTIFICATION_EMAIL_PRIMARY_PROVIDER=MAILGUN
NOTIFICATION_EMAIL_SECONDARY_PROVIDER=TWILIO
NOTIFICATION_EMAIL_SECONDARY_FAILOVER_ENABLED=false
NOTIFICATION_EMAIL_FROM=verified-sender@yourdomain.com

# Provider 1: Twilio Email (SendGrid API) - secondary
NOTIFICATION_TWILIO_EMAIL_ENABLED=false
NOTIFICATION_TWILIO_SENDGRID_API_KEY=
# Example secret ref:
# NOTIFICATION_TWILIO_SENDGRID_API_KEY_SECRET=neilsolar/local/notification#sendgrid_api_key
# OR (GCP short name): notification-twilio-sendgrid-api-key
NOTIFICATION_TWILIO_SENDGRID_API_KEY_SECRET=
NOTIFICATION_TWILIO_SENDGRID_TIMEOUT_SECONDS=10

# Provider 2: Mailgun - primary
NOTIFICATION_MAILGUN_ENABLED=true
NOTIFICATION_MAILGUN_DOMAIN=
NOTIFICATION_MAILGUN_API_KEY=
# Example secret ref:
# NOTIFICATION_MAILGUN_API_KEY_SECRET=neilsolar/local/notification#mailgun_api_key
# OR (GCP short name): notification-mailgun-api-key
NOTIFICATION_MAILGUN_API_KEY_SECRET=
NOTIFICATION_MAILGUN_EU_REGION=false
NOTIFICATION_MAILGUN_TIMEOUT_SECONDS=10

# Optional SMTP provider (if you switch provider chain to SMTP)
NOTIFICATION_EMAIL_SMTP_HOST=smtp.gmail.com
NOTIFICATION_EMAIL_SMTP_PORT=587
NOTIFICATION_EMAIL_SMTP_USER=
NOTIFICATION_EMAIL_SMTP_PASSWORD=
NOTIFICATION_EMAIL_SMTP_PASSWORD_SECRET=
NOTIFICATION_EMAIL_SMTP_SSL=false
NOTIFICATION_EMAIL_SMTP_STARTTLS=true

# Twilio WhatsApp secret ref (if TWILIO_ENABLED=true)
TWILIO_AUTH_TOKEN_SECRET=

# Recipient fallback env vars are deprecated.
# Notification recipients are resolved from DB profile data (site/customer contacts).
