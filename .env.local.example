API_PORT=8080
POSTGRES_PORT=5432
ADMINER_PORT=8081

POSTGRES_DB=neilsolar_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API local DB URLs (container-to-container via service name "postgres")
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/neilsolar_local
DATABASE_ADMIN_URL=postgresql+psycopg://postgres:postgres@postgres:5432/neilsolar_local

# Local-only bootstrap/admin convenience
BOOTSTRAP_ADMIN_KEY=dev-bootstrap-key
AUTH_DISABLED=true
APP_ENV=local

NOTIFICATION_ARCHIVE_INTERVAL_SECONDS=3600
NOTIFICATION_PURGE_INTERVAL_SECONDS=86400
NOTIFICATION_MAINTENANCE_RUN_ONCE=false
NOTIFICATION_RETENTION_ACTIVE_DAYS_DEFAULT=7
NOTIFICATION_RETENTION_HISTORY_DAYS_DEFAULT=365
NOTIFICATION_RETENTION_DEAD_LETTER_DAYS_DEFAULT=365
NOTIFICATION_PURGE_AFTER_DEACTIVATION_DAYS_DEFAULT=90

# Secret provider mode: ENV | VAULT | GCP
SECRET_PROVIDER=ENV
SECRET_FAIL_OPEN=true
SECRET_CACHE_TTL_SECONDS=300
SECRET_FETCH_TIMEOUT_SECONDS=10

# Local Vault (for SECRET_PROVIDER=VAULT)
VAULT_ADDR=http://host.docker.internal:8200
VAULT_TOKEN=
VAULT_MOUNT=secret
VAULT_KV_VERSION=2

# GCP Secret Manager (for SECRET_PROVIDER=GCP)
GCP_PROJECT_ID=

# Optional secret refs (inline env values still work when these are empty)
NOTIFICATION_MAILGUN_API_KEY_SECRET=
NOTIFICATION_TWILIO_SENDGRID_API_KEY_SECRET=
TWILIO_AUTH_TOKEN_SECRET=
NOTIFICATION_EMAIL_SMTP_PASSWORD_SECRET=

# Report storage/runtime
REPORT_STORAGE_BACKEND=AUTO
LOCAL_REPORTS_DIR=/tmp/neilsolar-reports
