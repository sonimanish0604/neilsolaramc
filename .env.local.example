API_PORT=8080
POSTGRES_PORT=5432
ADMINER_PORT=8081

POSTGRES_DB=neilsolar_local
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# API local DB URLs (container-to-container via service name "postgres")
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/neilsolar_local
DATABASE_ADMIN_URL=postgresql+psycopg://postgres:postgres@postgres:5432/neilsolar_local

# Local-only bootstrap/admin convenience
BOOTSTRAP_ADMIN_KEY=dev-bootstrap-key
AUTH_DISABLED=true
APP_ENV=local

